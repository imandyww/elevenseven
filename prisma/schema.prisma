// Agent Dollar Store — payments, wallets, and agent spending.
//
// Postgres. DATABASE_URL should be the pooled (PgBouncer) connection string
// with ?pgbouncer=true; DIRECT_URL the unpooled one for migrations.
// Remaining TODO: String columns marked "json:" should become Json (touches
// JSON.parse/stringify call sites — deferred).
//
// A hand-written migration adds CHECK ("balanceAfterCents" >= 0) on
// LedgerEntry as a backstop to the serializable-transaction invariant.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationSource {
  seed
  self_serve
  manual
}

enum PilotLeadStatus {
  new
  contacted
  won
  lost
}

enum LedgerEntryType {
  credit
  debit
  refund
  adjustment
}

enum CheckoutIntentStatus {
  open
  paid
  expired
  cancelled
}

enum AuditActorType {
  user
  agent
  system
}

enum AgentStatus {
  active
  paused
  revoked
}

enum OrderStatus {
  completed
  failed
  refunded
}

enum FundingRequestStatus {
  open
  funded
  cancelled
}

enum StandingOrderCadence {
  daily
}

enum StandingOrderStatus {
  requested
  active
  paused
  cancelled
}

model Organization {
  id           String   @id // seeded as "org_demo"; self-serve orgs use org_<hex>
  name         String
  billingEmail String?
  website      String?
  source       OrganizationSource @default(seed)
  stripeCustomerId String? @unique
  createdAt    DateTime @default(now())

  wallet Wallet?
  agents Agent[]
  orders Order[]
  fundingRequests FundingRequest[]
  standingOrders StandingOrder[]
  checkoutIntents CheckoutIntent[]
}

model PilotLead {
  id                    String   @id @default(cuid())
  organizationName      String
  contactName           String?
  email                 String
  website               String?
  useCase               String
  targetDailySpendCents Int      @default(100000)
  requestedSku          String   @default("thousand-dollar-day-pack")
  status                PilotLeadStatus @default(new)
  source                String   @default("pilot_page")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model Wallet {
  id             String   @id @default(cuid())
  organizationId String   @unique
  currency       String   @default("usd")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  entries      LedgerEntry[]

  // No balance column on purpose: the immutable ledger is the source of
  // truth. Balance = balanceAfterCents of the latest LedgerEntry.
}

model LedgerEntry {
  id                String   @id @default(cuid())
  walletId          String
  organizationId    String
  agentId           String?
  orderId           String?
  type              LedgerEntryType
  amountCents       Int // always positive; `type` carries direction
  balanceAfterCents Int
  source            String // "stripe_checkout" | "agent_purchase" | "dev_grant"
  externalRef       String?
  idempotencyKey    String?  @unique // "stripe:<eventId>" | "purchase:<agentId>:<key>" | "grant:<nonce>"
  createdAt         DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model StripeEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
  rawJson       String // json:
}

model CheckoutIntent {
  id                 String    @id @default(cuid())
  organizationId     String
  bundleId           String
  amountCents        Int
  creditsCents       Int
  status             CheckoutIntentStatus @default(open)
  stripeSessionId    String    @unique
  stripeCustomerId   String?
  checkoutUrl        String?
  recoveryToken      String?   @unique
  followupCount      Int       @default(0)
  lastFollowedUpAt   DateTime?
  returnPath         String
  fundingRequestId   String?
  standingOrderId    String?
  paidAt             DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status, createdAt])
  @@index([status, createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorType      AuditActorType
  actorId        String?
  action         String // e.g. "wallet.credited", "purchase.completed", "purchase.denied", "policy.updated"
  metadataJson   String // json:
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
}

model Agent {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  status         AgentStatus @default(active)
  keyHash        String    @unique // sha256 hex of the raw API key
  keyPrefix      String // e.g. "ag_live_a1b2" — display only, never the raw key
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  policy       AgentPolicy?
  orders       Order[]
  fundingRequests FundingRequest[]
  standingOrders StandingOrder[]

  @@index([organizationId])
}

model AgentPolicy {
  id                            String   @id @default(cuid())
  agentId                       String   @unique
  dailyLimitCents               Int      @default(500000)
  monthlyLimitCents             Int      @default(10000000)
  perPurchaseLimitCents         Int      @default(100000)
  allowedCategoriesJson         String   @default("[]") // json: [] = all categories allowed
  blockedSkusJson               String   @default("[]") // json:
  requireHumanApprovalOverCents Int      @default(100000)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
}

model Order {
  id             String   @id @default(cuid())
  organizationId String
  agentId        String
  totalCents     Int
  status         OrderStatus
  reason         String?
  idempotencyKey String
  requestHash    String // sha256 of the canonical request body, for replay-vs-conflict detection
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  agent        Agent         @relation(fields: [agentId], references: [id])
  items        OrderItem[]
  receipt      Receipt?
  entitlements Entitlement[]

  @@unique([agentId, idempotencyKey])
  @@index([agentId, createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  sku            String
  name           String
  quantity       Int
  unitPriceCents Int
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model Receipt {
  id             String   @id @default(cuid())
  orderId        String   @unique
  organizationId String
  agentId        String
  receiptJson    String // json: frozen wire purchase response
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([agentId, createdAt])
}

model Entitlement {
  id             String    @id @default(cuid())
  organizationId String
  agentId        String
  orderId        String
  sku            String
  manifestJson   String // json:
  allowedUses    Int
  remainingUses  Int
  expiresAt      DateTime?
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order        Order                    @relation(fields: [orderId], references: [id])
  consumptions EntitlementConsumption[]

  @@index([agentId])
}

model FundingRequest {
  id                  String   @id @default(cuid())
  organizationId      String
  agentId             String
  sku                 String
  productName         String
  quantity            Int      @default(1)
  totalCents          Int
  currentBalanceCents Int      @default(0)
  shortfallCents      Int
  recommendedBundleId String
  reason              String?
  status              FundingRequestStatus @default(open)
  source              String   @default("agent_api") // "agent_api" | "purchase_denied"
  idempotencyKey      String   @unique
  requestHash         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  agent        Agent        @relation(fields: [agentId], references: [id])

  @@index([organizationId, status, createdAt])
  @@index([agentId, createdAt])
}

model StandingOrder {
  id                   String    @id @default(cuid())
  organizationId       String
  agentId              String
  sku                  String
  productName          String
  quantity             Int       @default(1)
  totalCents           Int
  cadence              StandingOrderCadence @default(daily)
  status               StandingOrderStatus  @default(requested)
  reason               String
  idempotencyKey       String    @unique
  requestHash          String
  lastRunAt            DateTime?
  lastRunStatus        String?
  lastOrderId          String?
  lastFundingRequestId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  agent        Agent        @relation(fields: [agentId], references: [id])

  @@index([organizationId, status, createdAt])
  @@index([agentId, createdAt])
  @@index([status, cadence, lastRunAt])
}

model EntitlementConsumption {
  id             String   @id @default(cuid())
  entitlementId  String
  agentId        String
  idempotencyKey String
  createdAt      DateTime @default(now())

  entitlement Entitlement @relation(fields: [entitlementId], references: [id])

  @@unique([agentId, idempotencyKey])
}
