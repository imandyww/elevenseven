// Agent Dollar Store — payments, wallets, and agent spending.
//
// SQLite notes (Postgres migration TODOs):
// - String columns marked "enum:" should become real enums.
// - String columns marked "json:" should become Json.
// - Add CHECK (balance_after_cents >= 0) on LedgerEntry; today the
//   non-negative invariant is enforced inside serializable transactions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id // seeded as "org_demo"
  name      String
  createdAt DateTime @default(now())

  wallet Wallet?
  agents Agent[]
  orders Order[]
}

model Wallet {
  id             String   @id @default(cuid())
  organizationId String   @unique
  currency       String   @default("usd")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  entries      LedgerEntry[]

  // No balance column on purpose: the immutable ledger is the source of
  // truth. Balance = balanceAfterCents of the latest LedgerEntry.
}

model LedgerEntry {
  id                String   @id @default(cuid())
  walletId          String
  organizationId    String
  agentId           String?
  orderId           String?
  type              String // enum: "credit" | "debit" | "refund" | "adjustment"
  amountCents       Int // always positive; `type` carries direction
  balanceAfterCents Int
  source            String // "stripe_checkout" | "agent_purchase" | "dev_grant"
  externalRef       String?
  idempotencyKey    String?  @unique // "stripe:<eventId>" | "purchase:<agentId>:<key>" | "grant:<nonce>"
  createdAt         DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model StripeEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
  rawJson       String // json:
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorType      String // enum: "user" | "agent" | "system"
  actorId        String?
  action         String // e.g. "wallet.credited", "purchase.completed", "purchase.denied", "policy.updated"
  metadataJson   String // json:
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
}

model Agent {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  status         String    @default("active") // enum: "active" | "paused" | "revoked"
  keyHash        String    @unique // sha256 hex of the raw API key
  keyPrefix      String // e.g. "ag_live_a1b2" — display only, never the raw key
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  policy       AgentPolicy?
  orders       Order[]

  @@index([organizationId])
}

model AgentPolicy {
  id                            String   @id @default(cuid())
  agentId                       String   @unique
  dailyLimitCents               Int      @default(100)
  monthlyLimitCents             Int      @default(1000)
  perPurchaseLimitCents         Int      @default(50)
  allowedCategoriesJson         String   @default("[]") // json: [] = all categories allowed
  blockedSkusJson               String   @default("[]") // json:
  requireHumanApprovalOverCents Int      @default(100)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
}

model Order {
  id             String   @id @default(cuid())
  organizationId String
  agentId        String
  totalCents     Int
  status         String // enum: "completed" | "failed" | "refunded"
  reason         String?
  idempotencyKey String
  requestHash    String // sha256 of the canonical request body, for replay-vs-conflict detection
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  agent        Agent         @relation(fields: [agentId], references: [id])
  items        OrderItem[]
  receipt      Receipt?
  entitlements Entitlement[]

  @@unique([agentId, idempotencyKey])
  @@index([agentId, createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  sku            String
  name           String
  quantity       Int
  unitPriceCents Int
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model Receipt {
  id             String   @id @default(cuid())
  orderId        String   @unique
  organizationId String
  agentId        String
  receiptJson    String // json: frozen wire purchase response
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([agentId, createdAt])
}

model Entitlement {
  id             String    @id @default(cuid())
  organizationId String
  agentId        String
  orderId        String
  sku            String
  manifestJson   String // json:
  allowedUses    Int
  remainingUses  Int
  expiresAt      DateTime?
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order        Order                    @relation(fields: [orderId], references: [id])
  consumptions EntitlementConsumption[]

  @@index([agentId])
}

model EntitlementConsumption {
  id             String   @id @default(cuid())
  entitlementId  String
  agentId        String
  idempotencyKey String
  createdAt      DateTime @default(now())

  entitlement Entitlement @relation(fields: [entitlementId], references: [id])

  @@unique([agentId, idempotencyKey])
}
